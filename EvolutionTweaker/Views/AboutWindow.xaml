<Window x:Class="EvolutionTweaker.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе"
        Height="420" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{StaticResource BackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <!-- ИСПРАВЛЕНО: добавлен LastChildFill="False" -->
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" Text="О программе"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="20,0,0,0"/>
                    
                    <!-- Кнопка закрыть СПРАВА — с красной анимацией -->
                    <Button DockPanel.Dock="Right" Content="✕"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="CloseButton_Click"/>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="32">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="EVOLUTION" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text=" TWEAKER" FontSize="28" FontWeight="Light"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <TextBlock Text="Версия 1.0 Beta" FontSize="14" 
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                <TextBlock TextWrapping="Wrap" FontSize="14" LineHeight="22"
                           Foreground="{StaticResource TextBrush}">
                    Evolution Tweaker — инструмент для тонкой настройки Windows с целью повышения производительности в играх и снижения системной задержки.
                </TextBlock>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,24,0,0">
                    <StackPanel>
                        <TextBlock Text="Разработчик" FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="Evolution Team" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource PrimaryButtonStyle}" Content="Закрыть"
                        HorizontalAlignment="Stretch" Padding="12" Margin="0,24,0,0"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>