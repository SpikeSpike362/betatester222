<Window x:Class="EvolutionTweaker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:EvolutionTweaker.Helpers"
        xmlns:material="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        Title="Evolution Tweaker"
        Height="720" Width="1100"
        MinWidth="900"
        MinHeight="550"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <helpers:SelectedCategoryVisibilityConverter x:Key="SelectedCategoryVisibilityConverter"/>
        <helpers:SelectedCategoryBrushConverter x:Key="SelectedCategoryBrushConverter"/>

        <!-- Подпись пункта: в свёрнутом виде шириной 0 и без левого отступа,
             при наведении на сайдбар — выезжает вместе с отступом 14. -->
        <Style x:Key="SidebarLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MaxWidth" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth" To="150" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" BeginTime="0:0:0.08"/>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="14,0,0,0" Duration="0:0:0.25"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth" To="0" Duration="0:0:0.18" BeginTime="0:0:0.05">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="8"
            UseLayoutRounding="True" SnapsToDevicePixels="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0" DockPanel.Dock="Left">
                        <TextBlock Text="EVOLUTION" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text=" TWEAKER" FontSize="13" FontWeight="Light"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <Button Content="🌐" Style="{StaticResource TitleBarButtonStyle}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="LanguageButton_Click" ToolTip="Язык"/>
                        <Button Content="ℹ" Style="{StaticResource TitleBarButtonStyle}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="AboutButton_Click" ToolTip="О программе"/>
                        <Button Content="—" Style="{StaticResource TitleBarButtonStyle}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="MinimizeButton_Click" ToolTip="Свернуть"/>
                        <Button Content="□" Style="{StaticResource TitleBarButtonStyle}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="MaximizeButton_Click" ToolTip="Развернуть"/>
                        <Button Content="✕" Style="{StaticResource TitleBarCloseButtonStyle}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="CloseButton_Click" ToolTip="Закрыть"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- САЙДБАР: раскрывается по наведению мыши (MouseEnter/Leave),
                     ширина анимируется 80 ↔ 200. Кнопки-гамбургера больше нет. -->
                <Border Grid.Column="0" Width="80"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                        MouseEnter="Sidebar_MouseEnter"
                        MouseLeave="Sidebar_MouseLeave">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width" To="200" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width" To="80" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <DockPanel>
                        <!-- Аватар внизу -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,16" HorizontalAlignment="Center">
                            <material:MaterialIcon Kind="AccountCircleOutline" Width="26" Height="26"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   ToolTip="{Binding Greeting}"/>
                        </StackPanel>

                        <!-- Навигация -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" DockPanel.Dock="Top">
                            <StackPanel Margin="0,12,0,0">

                                <!-- Главная -->
                                <Button Style="{StaticResource NavButtonStyle}" Height="48"
                                        Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                        ToolTip="Главная" Command="{Binding NavigateCommand}" CommandParameter="dashboard">
                                    <Border CornerRadius="10" Padding="10,7"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Margin" Value="18,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Margin" Value="12,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Border CornerRadius="10" Background="#FFFFFF" IsHitTestVisible="False" Margin="-10,-7">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource SelectedCategoryVisibilityConverter}">
                                                        <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                    </MultiBinding>
                                                </Border.Visibility>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="HomeOutline" Width="22" Height="22">
                                                    <material:MaterialIcon.Foreground>
                                                        <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                            <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                        </MultiBinding>
                                                    </material:MaterialIcon.Foreground>
                                                </material:MaterialIcon>
                                                <TextBlock Text="Главная" Style="{StaticResource SidebarLabelStyle}">
                                                    <TextBlock.Foreground>
                                                        <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                            <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>

                                <!-- Оптимизация -->
                                <Button Style="{StaticResource NavButtonStyle}" Height="48"
                                        Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                        ToolTip="Оптимизация" Command="{Binding NavigateCommand}" CommandParameter="optimization">
                                    <Border CornerRadius="10" Padding="10,7"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Margin" Value="18,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Margin" Value="12,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Border CornerRadius="10" Background="#FFFFFF" IsHitTestVisible="False" Margin="-10,-7">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource SelectedCategoryVisibilityConverter}">
                                                        <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                    </MultiBinding>
                                                </Border.Visibility>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="Speedometer" Width="22" Height="22">
                                                    <material:MaterialIcon.Foreground>
                                                        <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                            <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                        </MultiBinding>
                                                    </material:MaterialIcon.Foreground>
                                                </material:MaterialIcon>
                                                <TextBlock Text="Оптимизация" Style="{StaticResource SidebarLabelStyle}">
                                                    <TextBlock.Foreground>
                                                        <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                            <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>

                                <!-- Инструменты -->
                                <Button Style="{StaticResource NavButtonStyle}" Height="48"
                                        Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                        ToolTip="Инструменты" Command="{Binding NavigateCommand}" CommandParameter="tools">
                                    <Border CornerRadius="10" Padding="10,7"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Margin" Value="18,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Margin" Value="12,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Border CornerRadius="10" Background="#FFFFFF" IsHitTestVisible="False" Margin="-10,-7">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource SelectedCategoryVisibilityConverter}">
                                                        <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                    </MultiBinding>
                                                </Border.Visibility>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="ViewGridOutline" Width="22" Height="22">
                                                    <material:MaterialIcon.Foreground>
                                                        <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                            <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                        </MultiBinding>
                                                    </material:MaterialIcon.Foreground>
                                                </material:MaterialIcon>
                                                <TextBlock Text="Инструменты" Style="{StaticResource SidebarLabelStyle}">
                                                    <TextBlock.Foreground>
                                                        <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                            <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>

                                <Border Margin="14,12,14,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"/>

                                <!-- Настройки -->
                                <Button Style="{StaticResource NavButtonStyle}" Height="48"
                                        Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                        ToolTip="Настройки" Command="{Binding NavigateCommand}" CommandParameter="settings">
                                    <Border CornerRadius="10" Padding="10,7"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Margin" Value="18,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Margin" Value="12,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Border CornerRadius="10" Background="#FFFFFF" IsHitTestVisible="False" Margin="-10,-7">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource SelectedCategoryVisibilityConverter}">
                                                        <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                    </MultiBinding>
                                                </Border.Visibility>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="CogOutline" Width="22" Height="22">
                                                    <material:MaterialIcon.Foreground>
                                                        <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                            <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                        </MultiBinding>
                                                    </material:MaterialIcon.Foreground>
                                                </material:MaterialIcon>
                                                <TextBlock Text="Настройки" Style="{StaticResource SidebarLabelStyle}">
                                                    <TextBlock.Foreground>
                                                        <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                            <Binding Path="DataContext.ActiveSection" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource AncestorType=Button}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- КОНТЕНТ -->
                <Grid Grid.Column="1">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"
                           helpers:PageTransition.Enabled="True"
                           Background="{StaticResource BackgroundBrush}"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>