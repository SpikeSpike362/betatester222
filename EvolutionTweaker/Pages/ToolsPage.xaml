<Page x:Class="EvolutionTweaker.Pages.ToolsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Style="{StaticResource PageStyle}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28">
            <TextBlock Text="Инструменты" Style="{StaticResource HeaderTextStyle}"/>
            <ItemsControl ItemsSource="{Binding Tools}" Margin="0,20,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                Padding="20" Margin="0,0,12,12" Width="240" Height="120">
                            <StackPanel>
                                <TextBlock Text="{Binding Icon}" FontSize="26"/>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" Margin="0,8,0,0"/>
                                <TextBlock Text="Скоро доступно"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>