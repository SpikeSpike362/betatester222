<Page x:Class="EvolutionTweaker.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Style="{StaticResource PageStyle}">

    <StackPanel Margin="32,28" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="Настройки" Style="{StaticResource HeaderTextStyle}"/>

        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
            <StackPanel>
                <TextBlock Text="Язык" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                          Margin="0,10,0,0" Width="200" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>