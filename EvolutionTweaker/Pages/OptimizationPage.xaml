<Page x:Class="EvolutionTweaker.Pages.OptimizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:EvolutionTweaker.Helpers"
      xmlns:material="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
      Style="{StaticResource PageStyle}">
    <Page.Resources>
        <SolidColorBrush x:Key="NavSelectedBrush" Color="#FFFFFF"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <helpers:NonEmptyStringToVisibilityConverter x:Key="NonEmptyToVisConverter"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
        <helpers:SelectedCategoryVisibilityConverter x:Key="SelectedCategoryVisibilityConverter"/>
        <helpers:SelectedCategoryBrushConverter x:Key="SelectedCategoryBrushConverter"/>

        <DataTemplate x:Key="DebloatCardTemplate">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,14,0"
                                   Visibility="{Binding HasSizeText, Converter={StaticResource BoolToVisConverter}}"/>
                        <TextBlock Text="будет удалено" Foreground="{StaticResource YellowBrush}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   Visibility="{Binding IsPendingUninstall, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Padding="16,8" FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                Content="{Binding ToggleLabel}" IsEnabled="{Binding CanToggle}"
                                Command="{Binding DataContext.TogglePendingCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                    <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ToggleIsDanger}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource RedBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Image Source="{Binding RealIcon}" Width="22" Height="22" Margin="0,0,12,0" Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding HasRealIcon, Converter={StaticResource BoolToVisConverter}}"/>
                            <material:MaterialIcon Kind="{Binding Info.IconKind}" Width="22" Height="22" Margin="0,0,12,0"
                                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"
                                                   Visibility="{Binding HasRealIcon, Converter={StaticResource InverseBoolToVisConverter}}"/>
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"
                                       Visibility="{Binding HasDisplayName, Converter={StaticResource BoolToVisConverter}}"/>
                            <TextBlock Text="{Binding Info.Name}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"
                                       Visibility="{Binding HasDisplayName, Converter={StaticResource InverseBoolToVisConverter}}"/>
                            <TextBlock Text="  ⚠ перезагрузка" Foreground="{StaticResource YellowBrush}" FontSize="11"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding Info.RequiresReboot, Converter={StaticResource BoolToVisConverter}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Info.Description}" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" TextWrapping="Wrap" MaxWidth="560"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Оптимизация" Style="{StaticResource HeaderTextStyle}" Margin="20,20,20,16"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Categories}" Margin="10,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- Заливка только у выбранной категории -->
                                    <Border CornerRadius="6" Margin="0,2" IsHitTestVisible="False"
                                            Background="{StaticResource NavSelectedBrush}">
                                        <Border.Visibility>
                                            <MultiBinding Converter="{StaticResource SelectedCategoryVisibilityConverter}">
                                                <Binding/>
                                                <Binding Path="DataContext.SelectedCategory"
                                                        RelativeSource="{RelativeSource AncestorType=Page}"/>
                                            </MultiBinding>
                                        </Border.Visibility>
                                    </Border>
                                    <!-- Кнопка поверх: прозрачна в покое, при наведении даёт свою обводку -->
                                    <Button Style="{StaticResource NavButtonStyle}"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <material:MaterialIcon Kind="{Binding Icon}" Width="18" Height="18"
                                                                Margin="0,0,12,0" VerticalAlignment="Center">
                                                <material:MaterialIcon.Foreground>
                                                    <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                        <Binding/>
                                                        <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                    </MultiBinding>
                                                </material:MaterialIcon.Foreground>
                                            </material:MaterialIcon>
                                            <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <MultiBinding Converter="{StaticResource SelectedCategoryBrushConverter}">
                                                        <Binding/>
                                                        <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                    </MultiBinding>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top" Padding="28,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding SelectedCategory.Name}" Style="{StaticResource HeaderTextStyle}"/>
            </Border>
            <Border DockPanel.Dock="Bottom" Padding="28,16" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Button Style="{StaticResource PrimaryButtonStyle}" Content="{Binding ApplyButtonText}" IsEnabled="{Binding CanApply}"
                        Command="{Binding OpenApplyOverlayCommand}" HorizontalAlignment="Right" Padding="28,12" FontSize="14"/>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="8"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False">
                                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border x:Name="thumbBg" CornerRadius="4" Margin="2,0" Background="#3A3A3A"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="thumbBg" Property="Background" Value="#555555"/></Trigger>
                                                                <Trigger Property="IsDragging" Value="True"><Setter TargetName="thumbBg" Property="Background" Value="#6E6E6E"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False">
                                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel Margin="28,20">

                    <!-- ОБЫЧНЫЕ ТВИКИ -->
                    <ItemsControl ItemsSource="{Binding CurrentTweaks}"
                                  Visibility="{Binding IsDebloatCategory, Converter={StaticResource InverseBoolToVisConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border helpers:StaggeredReveal.Enabled="True"
                                    Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,10">
                                    <StackPanel>
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StateText}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#F87171"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOptimal}" Value="True">
                                                                    <DataTrigger.EnterActions><BeginStoryboard><Storyboard>
                                                                        <ColorAnimation Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" To="#4ADE80" Duration="0:0:0.3"><ColorAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction></ColorAnimation>
                                                                    </Storyboard></BeginStoryboard></DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions><BeginStoryboard><Storyboard>
                                                                        <ColorAnimation Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" To="#F87171" Duration="0:0:0.3"><ColorAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction></ColorAnimation>
                                                                    </Storyboard></BeginStoryboard></DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding SliderValue}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                                <material:MaterialIcon Kind="{Binding Info.IconKind}" Width="22" Height="22" Margin="0,0,12,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="Transparent" Padding="2,10" Margin="-2,-10">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Info.Name}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                                                    <Grid Width="14" Height="14" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                        <Path Data="M 0,0 L 7,7 L 14,0" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <Path.RenderTransform><RotateTransform x:Name="arrowRotation" Angle="0" CenterX="7" CenterY="3.5"/></Path.RenderTransform>
                                                                        </Path>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <DataTrigger.EnterActions><BeginStoryboard><Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="arrowRotation" Storyboard.TargetProperty="Angle" To="180" Duration="0:0:0.3"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                    </Storyboard></BeginStoryboard></DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions><BeginStoryboard><Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="arrowRotation" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.3"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                    </Storyboard></BeginStoryboard></DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </DockPanel>

                                        <!-- РАСКРЫТИЕ ОПИСАНИЯ (плавное, через SmoothExpander) -->
                                        <Border helpers:SmoothExpander.IsExpanded="{Binding IsExpanded}"
                                                Height="0"
                                                ClipToBounds="True"
                                                Margin="34,0,0,0"
                                                Padding="12"
                                                Background="#0F0F0F"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Info.DetailedDescription}" TextWrapping="Wrap"
                                                        Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                <TextBlock Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap">
                                                    <Run Text="💡 " Foreground="{StaticResource YellowBrush}"/><Run Text="Рекомендация: " FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/><Run Text="{Binding Info.Recommendation, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </TextBlock>
                                                <TextBlock Margin="0,6,0,0" FontSize="12" TextWrapping="Wrap"
                                                        Visibility="{Binding Info.ImpactWarning, Converter={StaticResource NonEmptyToVisConverter}}">
                                                    <Run Text="⚠ " Foreground="{StaticResource RedBrush}"/><Run Text="{Binding Info.ImpactWarning, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- DEBLOAT -->
                    <StackPanel Visibility="{Binding IsDebloatCategory, Converter={StaticResource BoolToVisConverter}}">
                        <TextBlock Text="Проверка установленных приложений..." Foreground="{StaticResource TextSecondaryBrush}"
                                   Visibility="{Binding DebloatVm.IsLoading, Converter={StaticResource BoolToVisConverter}}" Margin="0,20"/>

                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="24" Margin="0,20,0,0"
                                Visibility="{Binding DebloatVm.HasNoInstalledItems, Converter={StaticResource BoolToVisConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <material:MaterialIcon Kind="CheckCircle" Width="64" Height="64" Foreground="{StaticResource GreenBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Система чиста!" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                                <TextBlock Text="На вашем ПК не найдено предустановленных приложений для удаления." Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="400" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- ВЕРХНИЙ БЛОК БЕЗ КАТЕГОРИИ -->
                        <StackPanel Visibility="{Binding DebloatVm.IsLoading, Converter={StaticResource InverseBoolToVisConverter}}">
                            <ContentControl Content="{Binding DebloatVm.OneDriveItem}" ContentTemplate="{StaticResource DebloatCardTemplate}"/>
                            <Border DataContext="{Binding DebloatVm.TeamsVm}" Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                    Padding="18" Margin="0,0,0,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StateText}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#F87171"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOptimal}" Value="True">
                                                            <DataTrigger.EnterActions><BeginStoryboard><Storyboard>
                                                                <ColorAnimation Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" To="#4ADE80" Duration="0:0:0.3"><ColorAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction></ColorAnimation>
                                                            </Storyboard></BeginStoryboard></DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions><BeginStoryboard><Storyboard>
                                                                <ColorAnimation Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" To="#F87171" Duration="0:0:0.3"><ColorAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction></ColorAnimation>
                                                            </Storyboard></BeginStoryboard></DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding SliderValue}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <material:MaterialIcon Kind="AccountGroup" Width="22" Height="22" Margin="0,0,12,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Автоустановка MS Teams" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Автоматически устанавливает Microsoft Teams при входе в систему. Оптимально — отключить." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" MaxWidth="560"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        <!-- ГРУППЫ -->
                        <ItemsControl ItemsSource="{Binding DebloatVm.Groups}"
                                      Visibility="{Binding DebloatVm.IsLoading, Converter={StaticResource InverseBoolToVisConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,24">
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

                                        <!-- Табличка-предупреждение для "Других" -->
                                        <Border Visibility="{Binding IsOther, Converter={StaticResource BoolToVisConverter}}" Background="#1A0F0F" CornerRadius="6"
                                                Padding="12" Margin="0,0,0,12" BorderBrush="#3A2020" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <material:MaterialIcon Kind="AlertOutline" Width="18" Height="18" Foreground="{StaticResource RedBrush}" VerticalAlignment="Top" Margin="0,1,10,0"/>
                                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" MaxWidth="640">
                                                    <Run Text="Внимание! " FontWeight="SemiBold" Foreground="{StaticResource RedBrush}"/><Run Text="Приложения ниже не из нашего списка. Удаляйте только если точно знаете, что делаете — некоторые могут оказаться нужны системе или другим программам."/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource DebloatCardTemplate}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- МОДАЛКА -->
        <Border Grid.ColumnSpan="2" Background="#CC000000" Visibility="{Binding ShowApplyOverlay, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="32" Margin="80"
                    VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="700">
                <StackPanel>
                    <TextBlock Text="Применить изменения?" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,16"/>
                    <TextBlock Text="Следующие изменения будут применены. Обратите внимание на предупреждения." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="8" MaxHeight="300">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding PendingPreview}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12" Margin="0,4" Background="{StaticResource SurfaceHoverBrush}" CornerRadius="6">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <material:MaterialIcon Kind="{Binding Icon}" Width="18" Height="18" Margin="0,0,10,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Text="  →  " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Action}" Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Warning}" TextWrapping="Wrap" Foreground="{StaticResource YellowBrush}" FontSize="11" Margin="28,6,0,0"
                                                           Visibility="{Binding Warning, Converter={StaticResource NonEmptyToVisConverter}}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Style="{StaticResource BaseButtonStyle}" Content="Отмена" Command="{Binding CancelApplyCommand}" Padding="20,10" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Применить" Command="{Binding ConfirmApplyCommand}" Padding="20,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>